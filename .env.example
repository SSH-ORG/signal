DATABASE_URL=postgresql://user:password@localhost:5432/signal_db

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Random secret used to sign and encrypt session cookies — keep this private
SESSION_SECRET=your-secret-key-here

# Gemini API key — used to generate AI confusion reports from student submissions
GEMINI_API_KEY=your-gemini-api-key-here
